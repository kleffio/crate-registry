{
  "id": "terraria-vanilla",
  "crate": "terraria",
  "construct": "steamcmd",
  "name": "Terraria",
  "description": "Official Terraria dedicated server.",
  "logo": "",
  "version": "0.1.0",
  "official": true,
  "image": "ghcr.io/kleffio/constructs:steamcmd",
  "env": {
    "WORLD": "World",
    "AUTOCREATE": "2",
    "DIFFICULTY": "0",
    "MAXPLAYERS": "8",
    "PASSWORD": "",
    "AUTO_UPDATE": "0"
  },
  "ports": [
    {
      "name": "game",
      "container": 7777,
      "protocol": "tcp",
      "expose": true,
      "label": "Terraria"
    }
  ],
  "outputs": [
    {
      "key": "ADDRESS",
      "description": "Server address for players to connect to.",
      "value_template": "{{ .ContainerName }}:7777"
    }
  ],
  "config": [
    {
      "key": "TERRARIA_VERSION",
      "label": "Server Version",
      "description": "Terraria dedicated server version to download and run.",
      "type": "string",
      "default": "1.4.5.6",
      "required": false
    },
    {
      "key": "WORLD",
      "label": "World Name",
      "type": "string",
      "default": "World",
      "required": true
    },
    {
      "key": "AUTOCREATE",
      "label": "World Size",
      "description": "Auto-create a new world at this size if none exists.",
      "type": "select",
      "options": [
        "1",
        "2",
        "3"
      ],
      "default": "2",
      "required": false
    },
    {
      "key": "DIFFICULTY",
      "label": "World Difficulty",
      "type": "select",
      "options": [
        "0",
        "1",
        "2",
        "3"
      ],
      "default": "0",
      "required": false
    },
    {
      "key": "MAXPLAYERS",
      "label": "Max Players",
      "type": "number",
      "default": 8,
      "required": false
    },
    {
      "key": "PASSWORD",
      "label": "Server Password",
      "description": "Leave empty for a public server.",
      "type": "secret",
      "required": false
    }
  ],
  "resources": {
    "memory_mb": 1024,
    "cpu_millicores": 1000,
    "disk_gb": 5
  }
}
