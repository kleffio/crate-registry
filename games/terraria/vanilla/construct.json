{
  "id": "terraria-vanilla",
  "crate": "terraria",
  "blueprint": "terraria-vanilla",
  "image": "ghcr.io/kleffio/games:terraria-vanilla",
  "command": "mkdir -p /serverdata/Worlds && printf 'world=/serverdata/Worlds/%s.wld\\nautocreate=%s\\nworldname=%s\\ndifficulty=%s\\nmaxplayers=%s\\nport=7777\\npassword=%s\\n' \"${WORLD:-World}\" \"${AUTOCREATE:-2}\" \"${WORLD:-World}\" \"${DIFFICULTY:-0}\" \"${MAXPLAYERS:-8}\" \"${PASSWORD:-}\" > serverconfig.txt && tail -f /dev/null | ./TerrariaServer.bin.x86_64 -config serverconfig.txt",
  "version": "1.0.0",
  "env": {
    "WORLD": "World",
    "AUTOCREATE": "2",
    "DIFFICULTY": "0",
    "MAXPLAYERS": "8",
    "PASSWORD": ""
  },
  "ports": [
    {
      "name": "game",
      "container": 7777,
      "protocol": "tcp",
      "expose": true,
      "label": "Terraria"
    }
  ],
  "runtime_hints": {
    "kubernetes_strategy": "standard",
    "expose_udp": false,
    "persistent_storage": true,
    "storage_path": "/serverdata",
    "storage_gb": 5,
    "health_check_path": "",
    "health_check_port": 0
  },
  "outputs": [
    {
      "key": "ADDRESS",
      "description": "Server address for players to connect to.",
      "value_template": "{{ .ContainerName }}:7777"
    }
  ]
}
