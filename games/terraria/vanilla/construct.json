{
  "id": "terraria-vanilla",
  "crate": "terraria",
  "blueprint": "terraria-vanilla",
  "image": "ghcr.io/kleffio/games:terraria-vanilla",
  "version": "1.0.0",
  "env": {
    "WORLD": "World",
    "AUTOCREATE": "2",
    "DIFFICULTY": "0",
    "MAXPLAYERS": "8",
    "PASSWORD": ""
  },
  "ports": [
    {
      "name": "game",
      "container": 7777,
      "protocol": "tcp",
      "expose": true,
      "label": "Terraria"
    }
  ],
  "runtime_hints": {
    "kubernetes_strategy": "standard",
    "expose_udp": false,
    "persistent_storage": true,
    "storage_path": "/serverdata",
    "storage_gb": 5,
    "health_check_path": "",
    "health_check_port": 0
  },
  "outputs": [
    {
      "key": "ADDRESS",
      "description": "Server address for players to connect to.",
      "value_template": "{{ .ContainerName }}:7777"
    }
  ]
}
