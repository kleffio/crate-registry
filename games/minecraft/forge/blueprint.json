{
  "id": "minecraft-forge",
  "crate": "minecraft",
  "construct": "minecraft-forge",
  "name": "Forge",
  "description": "Modded Minecraft with Forge mod loader.",
  "logo": "",
  "version": "1.2.0",
  "official": true,
  "config": [
    {
      "key": "VERSION",
      "label": "Minecraft Version",
      "type": "select",
      "options": ["LATEST", "1.21.4", "1.20.4", "1.20.1"],
      "default": "LATEST",
      "required": true
    },
    {
      "key": "FORGEVERSION",
      "label": "Forge Version",
      "type": "string",
      "default": "RECOMMENDED",
      "required": false
    },
    {
      "key": "MAX_PLAYERS",
      "label": "Max Players",
      "type": "number",
      "default": 20,
      "required": false
    },
    {
      "key": "MEMORY",
      "label": "JVM Memory",
      "type": "string",
      "default": "4G",
      "required": false
    }
  ],
  "resources": {
    "memory_mb": 4096,
    "cpu_millicores": 2000,
    "disk_gb": 20
  },
  "extensions": {
    "mod": {
      "enabled": true,
      "sources": ["modrinth", "curseforge", "github-release", "upload"]
    }
  }
}
