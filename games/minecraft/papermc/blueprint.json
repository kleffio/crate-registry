{
  "id": "minecraft-papermc",
  "crate": "minecraft",
  "construct": "minecraft-papermc",
  "name": "PaperMC",
  "description": "High-performance Minecraft server fork with plugin support.",
  "logo": "",
  "version": "1.3.0",
  "official": true,
  "config": [
    {
      "key": "VERSION",
      "label": "Minecraft Version",
      "type": "select",
      "options": ["LATEST", "1.21.4", "1.21.3", "1.20.4", "1.20.1"],
      "default": "LATEST",
      "required": true
    },
    {
      "key": "DIFFICULTY",
      "label": "Difficulty",
      "type": "select",
      "options": ["peaceful", "easy", "normal", "hard"],
      "default": "normal",
      "required": false
    },
    {
      "key": "MAX_PLAYERS",
      "label": "Max Players",
      "type": "number",
      "default": 20,
      "required": false
    },
    {
      "key": "MOTD",
      "label": "MOTD",
      "description": "Message shown in the server list.",
      "type": "string",
      "default": "A Minecraft Server",
      "required": false
    },
    {
      "key": "RCON_PASSWORD",
      "label": "RCON Password",
      "type": "secret",
      "required": false,
      "auto_generate": true,
      "auto_generate_length": 16
    },
    {
      "key": "MEMORY",
      "label": "JVM Memory",
      "description": "Java heap size, e.g. 2G or 4G.",
      "type": "string",
      "default": "2G",
      "required": false
    }
  ],
  "resources": {
    "memory_mb": 2048,
    "cpu_millicores": 2000,
    "disk_gb": 10
  },
  "extensions": {
    "plugin": {
      "enabled": true,
      "sources": ["modrinth", "hangar", "spigotmc", "github-release", "upload"]
    }
  }
}
