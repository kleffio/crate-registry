{
  "id": "minecraft-velocity",
  "crate": "minecraft",
  "construct": "java-21",
  "name": "Velocity",
  "description": "High-performance Minecraft proxy server.",
  "logo": "",
  "version": "0.1.0",
  "official": true,
  "image": "ghcr.io/kleffio/constructs:java-21",
  "constructs": {
    "Java 21": "ghcr.io/kleffio/constructs:java-21",
    "Java 25": "ghcr.io/kleffio/constructs:java-25"
  },
  "env": {
    "VELOCITY_VERSION": "latest",
    "MIN_MEMORY": "512M",
    "SERVER_MEMORY": "512M",
    "AUTO_UPDATE": "0"
  },
  "ports": [
    {
      "name": "minecraft",
      "container": 25565,
      "protocol": "tcp",
      "expose": true,
      "label": "Minecraft Proxy"
    }
  ],
  "outputs": [
    {
      "key": "ADDRESS",
      "description": "Proxy address for players to connect to.",
      "value_template": "{{ .ContainerName }}:25565"
    }
  ],
  "runtime_hints": {
    "persistent_storage": false
  },
  "config": [
    {
      "key": "MEMORY",
      "label": "JVM Memory",
      "type": "string",
      "default": "1G",
      "required": false
    }
  ],
  "resources": {
    "memory_mb": 1024,
    "cpu_millicores": 1000,
    "disk_gb": 5
  },
  "extensions": {
    "plugin": {
      "enabled": true,
      "sources": ["modrinth", "hangar", "github-release", "upload"],
      "install_method": "jar-drop",
      "install_path": "/server/plugins/",
      "file_extension": ".jar",
      "config_path": "/server/plugins/",
      "requires_restart": true
    }
  }
}
