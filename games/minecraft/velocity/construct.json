{
  "id": "minecraft-velocity",
  "crate": "minecraft",
  "blueprint": "minecraft-velocity",
  "image": "ghcr.io/kleffio/games:minecraft-velocity",
  "version": "1.2.0",
  "env": {
    "TYPE": "VELOCITY"
  },
  "ports": [
    {
      "name": "minecraft",
      "container": 25565,
      "protocol": "tcp",
      "expose": true,
      "label": "Minecraft Proxy"
    }
  ],
  "runtime_hints": {
    "kubernetes_strategy": "agones",
    "expose_udp": false,
    "persistent_storage": false,
    "health_check_path": "",
    "health_check_port": 0
  },
  "extensions": {
    "plugin": {
      "install_method": "jar-drop",
      "install_path": "/server/plugins/",
      "file_extension": ".jar",
      "config_path": "/server/plugins/",
      "requires_restart": true
    }
  },
  "outputs": [
    {
      "key": "ADDRESS",
      "description": "Proxy address for players to connect to.",
      "value_template": "{{ .ContainerName }}:25565"
    }
  ]
}
