{
  "id": "ark-vanilla",
  "crate": "ark",
  "construct": "steamcmd",
  "name": "ARK: Survival Evolved",
  "description": "Standard ARK: Survival Evolved dedicated server.",
  "logo": "",
  "version": "0.1.0",
  "official": true,
  "image": "ghcr.io/kleffio/constructs:steamcmd",
  "env": {
    "MAP": "TheIsland",
    "SESSION_NAME": "ARK Server",
    "MAX_PLAYERS": "20",
    "SERVER_PASSWORD": "",
    "ADMIN_PASSWORD": "changeme",
    "AUTO_UPDATE": "0"
  },
  "ports": [
    {
      "name": "game",
      "container": 7777,
      "protocol": "udp",
      "expose": true,
      "label": "Game Port"
    },
    {
      "name": "query",
      "container": 27015,
      "protocol": "udp",
      "expose": true,
      "label": "Steam Query Port"
    },
    {
      "name": "rcon",
      "container": 27020,
      "protocol": "tcp",
      "expose": false,
      "label": "RCON"
    }
  ],
  "outputs": [
    {
      "key": "ADDRESS",
      "description": "Server address for players to connect to.",
      "value_template": "{{ .ContainerName }}:7777"
    }
  ],
  "config": [
    {
      "key": "SESSION_NAME",
      "label": "Server Name",
      "type": "string",
      "default": "My ARK Server",
      "required": true
    },
    {
      "key": "SERVER_PASSWORD",
      "label": "Server Password",
      "description": "Leave empty for a public server.",
      "type": "secret",
      "required": false
    },
    {
      "key": "ADMIN_PASSWORD",
      "label": "Admin Password",
      "type": "secret",
      "required": true,
      "auto_generate": true,
      "auto_generate_length": 16
    },
    {
      "key": "MAX_PLAYERS",
      "label": "Max Players",
      "type": "number",
      "default": 20,
      "required": false
    },
    {
      "key": "MAP",
      "label": "Map",
      "type": "select",
      "options": [
        "TheIsland",
        "TheCenter",
        "Ragnarok",
        "Aberration",
        "Extinction",
        "Valguero",
        "CrystalIsles",
        "GenOne",
        "GenTwo",
        "LostIsland",
        "Fjordur"
      ],
      "default": "TheIsland",
      "required": true
    },
    {
      "key": "PVP",
      "label": "PvP Mode",
      "type": "boolean",
      "default": false,
      "required": false
    }
  ],
  "resources": {
    "memory_mb": 8192,
    "cpu_millicores": 4000,
    "disk_gb": 50
  },
  "extensions": {
    "mod": {
      "enabled": true,
      "sources": ["steam-workshop", "upload"],
      "install_method": "steam-workshop",
      "install_path": "/ark/ShooterGame/Content/Mods/",
      "requires_restart": true
    }
  }
}
