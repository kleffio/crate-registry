{
  "id": "ark-vanilla",
  "crate": "ark",
  "blueprint": "ark-vanilla",
  "image": "ghcr.io/kleffio/games:ark-vanilla",
  "version": "1.0.0",
  "env": {},
  "ports": [
    {
      "name": "game",
      "container": 7777,
      "protocol": "udp",
      "expose": true,
      "label": "Game Port"
    },
    {
      "name": "query",
      "container": 27015,
      "protocol": "udp",
      "expose": true,
      "label": "Steam Query Port"
    },
    {
      "name": "rcon",
      "container": 27020,
      "protocol": "tcp",
      "expose": false,
      "label": "RCON"
    }
  ],
  "runtime_hints": {
    "kubernetes_strategy": "standard",
    "expose_udp": true,
    "persistent_storage": true,
    "health_check_path": "",
    "health_check_port": 0
  },
  "extensions": {
    "mod": {
      "install_method": "steam-workshop",
      "install_path": "/ark/ShooterGame/Content/Mods/",
      "requires_restart": true
    }
  },
  "outputs": [
    {
      "key": "ADDRESS",
      "description": "Server address for players to connect to.",
      "value_template": "{{ .ContainerName }}:7777"
    }
  ]
}
