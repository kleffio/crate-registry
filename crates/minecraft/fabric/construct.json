{
  "id": "minecraft-fabric",
  "crate": "minecraft",
  "blueprint": "minecraft-fabric",
  "image": "itzg/minecraft-server",
  "version": "1.1.0",
  "env": {
    "EULA": "TRUE",
    "TYPE": "FABRIC"
  },
  "ports": [
    {
      "name": "minecraft",
      "container": 25565,
      "protocol": "tcp",
      "expose": true,
      "label": "Minecraft (Java)"
    },
    {
      "name": "rcon",
      "container": 25575,
      "protocol": "tcp",
      "expose": false,
      "label": "RCON"
    }
  ],
  "runtime_hints": {
    "kubernetes_strategy": "agones",
    "expose_udp": false,
    "persistent_storage": true,
    "storage_path": "/data",
    "storage_gb": 15,
    "health_check_path": "",
    "health_check_port": 0
  },
  "extensions": {
    "mod": {
      "install_method": "jar-drop",
      "install_path": "/data/mods/",
      "file_extension": ".jar",
      "requires_restart": true
    }
  },
  "outputs": [
    {
      "key": "ADDRESS",
      "description": "Internal host:port.",
      "value_template": "{{ .ContainerName }}:25565"
    }
  ]
}
